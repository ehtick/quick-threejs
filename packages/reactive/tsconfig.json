{
	"extends": "@quick-threejs/config/typescript",
	"compilerOptions": {
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"removeComments": false,

		"baseUrl": "./src",
		"outDir": "./dist",
		"paths": {
			"@/*": ["./*"]
		}
	},
	"include": ["src"],
	"exclude": ["*.config.mjs", "*.config.ts"]
}
